generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Question {
  id          String   @id @default(uuid())
  mlQuestionId BigInt  @map("ml_question_id")
  itemId      String   @map("item_id")
  sellerId    BigInt   @map("seller_id")
  status      String
  text        String?  @db.Text
  dateCreated DateTime @map("date_created")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("question")
  @@index([sellerId], map: "idx_question_seller_id")
  @@index([itemId], map: "idx_question_item_id")
}
