NODE_ENV=development
PORT=3002

# Mongo (optional unless using /vectors/search)
MONGODB_URI=mongodb://mongo:27017/agent_ops
MONGODB_DB_NAME=agent_ops
MONGODB_VECTOR_COLLECTION=agent_embeddings
MONGODB_VECTOR_INDEX=vector_index

# LLM
OPENAI_API_KEY=your-openai-api-key
EMBEDDING_MODEL=text-embedding-3-small

# Agent Retriever (Mercado Livre proxy base URL)
# Example: http://localhost:3001
RETRIEVER_PROXY_ML_URL=http://localhost:3001

# Agent Questions (optional overrides)
# AGENT_QUESTIONS_LIMIT=10
# AGENT_QUESTIONS_INPUT_PATH=src/agent_retriever/outputs/unanswered-questions.json

