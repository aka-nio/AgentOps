## frontTest dev — read from this folder (see vite.config.ts `envDir`)

# Only `VITE_*` keys are used here. Set `ML_AGENTS_SERVER_URL` in **ml_intermediate_api/.env** (not in this file) so the Fastify proxy can reach ml_agents.

# Run: (1) ml_agents `npm run dev` on PORT 3000  (2) intermediate on 3001 with ML_AGENTS_SERVER_URL=http://127.0.0.1:3000
VITE_ML_AGENTS_SERVER_URL=http://127.0.0.1:3001
VITE_RETRIEVER_PROXY_ML_URL=http://127.0.0.1:3001

# If nothing listens on 3001, point both at ml_agents Node only (must be the only service on that port):
# VITE_ML_AGENTS_SERVER_URL=http://127.0.0.1:3000
# VITE_RETRIEVER_PROXY_ML_URL=http://127.0.0.1:3001
