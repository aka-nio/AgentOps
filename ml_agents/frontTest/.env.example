## Frontend demo env
#
# In dev, Vite will proxy:
# - /ml-agents/*       -> VITE_ML_AGENTS_SERVER_URL (Node: ml_agents/src/server.ts — health, invoke, agent-questions)
# - /retriever-api/*   -> VITE_RETRIEVER_PROXY_ML_URL (Fastify Mercado Livre proxy, e.g. ml_intermediate_api)

# Port must match ml_agents `PORT` (default 3000). If nothing listens there, Vite shows ECONNREFUSED.
# Must be the ml_agents Node HTTP server (`src/server.ts`), NOT the Mercado Fastify app — or you get HTTP 404 from Fastify.
VITE_ML_AGENTS_SERVER_URL=http://127.0.0.1:3000

# Optional: if you omit VITE_ML_AGENTS_SERVER_URL, Vite falls back to VITE_AGENT_API_URL (legacy name).
# VITE_AGENT_API_URL=http://localhost:3000

VITE_RETRIEVER_PROXY_ML_URL=http://localhost:3001
